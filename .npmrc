# pnpm configuration for Watch Hub Sync
# This file is read by pnpm (and corepack) on every install.

# Hoist peer deps the same way npm does — prevents "phantom" missing peers
# in Next.js + Radix UI component chains.
public-hoist-pattern[]=*@radix-ui/*
public-hoist-pattern[]=*@types/*

# Do NOT hoist everything (shamefully) — keeps the node_modules graph clean
# and prevents accidental use of transitive deps in application code.
shamefully-hoist=false

# Fail the install if the lockfile is out of date (enforces frozen installs in CI).
# Vercel passes --frozen-lockfile via vercel.json installCommand above.
strict-peer-dependencies=false

# Silence optional peer dependency warnings (e.g. @sveltejs/kit in @vercel/speed-insights).
# These are safe to ignore — we are a Next.js app, not a SvelteKit app.
auto-install-peers=true
