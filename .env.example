# =============================================================================
# CineRoom — Environment Variable Schema
# Copy to .env.local. NEVER commit .env.local to source control.
# All variables marked [REQUIRED] must be set before the app will start.
# =============================================================================

# --- Supabase --------------------------------------------------------------- #
# [REQUIRED] Supabase project URL (public, safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=https://jcupxklvupunpccmkmtu.supabase.co

# [REQUIRED] Supabase anon key (public, used by browser client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImpjdXB4a2x2dXB1bnBjY21rbXR1Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODE5MzU0MzYsImV4cCI6MjA5NzUxMTQzNn0.3SWnsqBzcK1QMZKwWai6W09eI0099Hdccmb3958JKVE

# [REQUIRED] Supabase service_role key (PRIVATE — server-only, bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImpjdXB4a2x2dXB1bnBjY21rbXR1Iiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc4MTkzNTQzNiwiZXhwIjoyMDk3NTExNDM2fQ.huHmPCsxbfdrHL1EEXSQgLxzDZKA48EsAW4cRcbgUBg

# --- LiveKit ---------------------------------------------------------------- #
# [REQUIRED] LiveKit Cloud API key (from livekit.io dashboard)
LIVEKIT_API_KEY=APIJE4heuyWeDBG

# [REQUIRED] LiveKit Cloud API secret
LIVEKIT_API_SECRET=XVLgzII7Sl6QYpFbx1a7D8ZmTKquDdvkH22m8FY9agP

# [REQUIRED] LiveKit Cloud WebSocket URL
NEXT_PUBLIC_LIVEKIT_URL=wss://watch-hub-sync-prod-ms6xo4r9.livekit.cloud

# [REQUIRED] LiveKit Webhook signing secret (for verifying room_finished events)
LIVEKIT_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Stripe ----------------------------------------------------------------- #
# [REQUIRED] Stripe publishable key (public)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_51RMEHuRdW0SowVkFI61IVWkD6146Si14UelFene5Hu0WTjPcgYGrYZqLcLD0EELPaezqOEcGRhcNRftHRPZHLdtz00WZItb2kf

# [REQUIRED] Stripe secret key (PRIVATE)
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# [REQUIRED] Stripe webhook signing secret (from stripe listen or dashboard)
STRIPE_WEBHOOK_SECRET=whsec_...

# [REQUIRED] Stripe Price ID for the CineRoom Premium subscription
STRIPE_PREMIUM_PRICE_ID=price_...

# [REQUIRED] Stripe Meter Event name for participant-minutes
STRIPE_METER_EVENT_NAME=cineroom_participant_minutes

# --- Razorpay --------------------------------------------------------------- #
# [REQUIRED] Razorpay Key ID (public)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_...

# [REQUIRED] Razorpay Key Secret (PRIVATE)
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# [REQUIRED] Razorpay Webhook Secret
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# [REQUIRED] Razorpay Subscription Plan ID for INR Premium tier
RAZORPAY_PREMIUM_PLAN_ID=plan_...

# --- Upstash Redis (Rate Limiting) ----------------------------------------- #
# [REQUIRED] Upstash Redis REST URL
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io

# [REQUIRED] Upstash Redis REST token
UPSTASH_REDIS_REST_TOKEN=AXxx...

# --- Magic Link / Invite ---------------------------------------------------- #
# [REQUIRED] HMAC-SHA256 secret for signing invite tokens (min 32 bytes)
INVITE_SIGNING_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [REQUIRED] Invite token TTL in seconds (default: 48 hours)
INVITE_TOKEN_TTL_SECONDS=172800

# --- App -------------------------------------------------------------------- #
# [REQUIRED] Canonical origin URL (no trailing slash)
NEXT_PUBLIC_APP_URL=https://cineroom.app

# [OPTIONAL] Vercel KV URL (for edge-cached geo lookups — falls back to inline)
KV_REST_API_URL=https://...
KV_REST_API_TOKEN=xxx...

# [OPTIONAL] IP Geolocation API key (ipinfo.io or similar)
GEO_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# [OPTIONAL] Log level: trace | debug | info | warn | error
LOG_LEVEL=info
