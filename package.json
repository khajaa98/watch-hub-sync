{
  "name": "cineroom",
  "version": "0.1.0",
  "private": true,
  "description": "CineRoom — India-first premium watch-together platform. Pure sync engine, zero proxy.",
  "packageManager": "pnpm@9.1.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "db:generate": "supabase gen types typescript --local > src/types/supabase.ts",
    "db:migrate": "supabase db push",
    "db:reset": "supabase db reset",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "analyze": "ANALYZE=true next build",
    "prepare": "husky install"
  },
  "dependencies": {
    "next": "14.2.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",

    "@supabase/supabase-js": "2.44.4",
    "@supabase/ssr": "0.3.0",

    "@livekit/components-react": "2.3.0",
    "@livekit/components-styles": "1.1.0",
    "livekit-client": "2.3.0",
    "livekit-server-sdk": "2.5.0",

    "@stripe/stripe-js": "4.1.0",
    "stripe": "16.2.0",

    "razorpay": "2.9.4",

    "zod": "3.23.8",
    "zustand": "4.5.4",
    "@tanstack/react-query": "5.51.1",
    "@tanstack/react-query-devtools": "5.51.1",

    "framer-motion": "11.3.8",
    "class-variance-authority": "0.7.0",
    "clsx": "2.1.1",
    "tailwind-merge": "2.4.0",
    "lucide-react": "0.414.0",

    "qrcode": "1.5.4",
    "@radix-ui/react-dialog": "1.1.1",
    "@radix-ui/react-dropdown-menu": "2.1.1",
    "@radix-ui/react-toast": "1.2.1",
    "@radix-ui/react-tooltip": "1.1.2",
    "@radix-ui/react-switch": "1.1.0",
    "@radix-ui/react-select": "2.1.1",
    "@radix-ui/react-avatar": "1.1.0",
    "@radix-ui/react-separator": "1.1.0",
    "@radix-ui/react-slot": "1.1.0",

    "nanoid": "5.0.7",
    "date-fns": "3.6.0",
    "ms": "2.1.3",
    "svix": "1.24.0",

    "jose": "5.6.3",
    "iron-session": "8.0.3",

    "pino": "9.3.2",
    "pino-pretty": "11.2.1",

    "@vercel/analytics": "1.3.1",
    "@vercel/speed-insights": "1.0.12",
    "@vercel/kv": "2.0.0",
    "@upstash/ratelimit": "2.0.1",
    "@upstash/redis": "1.34.0"
  },
  "devDependencies": {
    "typescript": "5.5.3",
    "@types/node": "20.14.11",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@types/qrcode": "1.5.5",
    "@types/ms": "0.7.34",

    "tailwindcss": "3.4.6",
    "autoprefixer": "10.4.19",
    "postcss": "8.4.39",

    "eslint": "8.57.0",
    "eslint-config-next": "14.2.5",
    "@typescript-eslint/eslint-plugin": "7.16.1",
    "@typescript-eslint/parser": "7.16.1",
    "eslint-plugin-import": "2.29.1",
    "eslint-plugin-tailwindcss": "3.17.4",

    "prettier": "3.3.3",
    "prettier-plugin-tailwindcss": "0.6.5",

    "vitest": "2.0.3",
    "@vitest/ui": "2.0.3",
    "@vitest/coverage-v8": "2.0.3",
    "@testing-library/react": "16.0.0",
    "@testing-library/user-event": "14.5.2",
    "jsdom": "24.1.1",

    "husky": "9.1.1",
    "lint-staged": "15.2.7",

    "supabase": "1.178.2",

    "@next/bundle-analyzer": "14.2.5",

    "tsx": "4.16.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx,json,md,css}": [
      "prettier --write"
    ]
  }
}
